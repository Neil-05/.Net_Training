@model List<MVC.Models.Employee>
<marquee><h1>Welcome to Employee Management System</h1></marquee>
<h2>Employees</h2>

<table border="1">
<tr>
    <th>Name</th>
    <th>Department</th>
    <th>Salary</th>
</tr>
@foreach (var employee in Model)
{
<tr>
    <td>@employee.FullName</td>
    <td>@employee.Dept</td>
    <td>@employee.Amount</td>
</tr>
}
</table>

<a asp-action="Create">Add Employees</a>
