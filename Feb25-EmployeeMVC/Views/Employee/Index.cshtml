@model IEnumerable<Employee>

<h2>Employee List</h2>

<a asp-action="Create" class="btn btn-primary">Add Employee</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var emp in Model)
    {
        <tr>
            <td>@emp.EmployeeId</td>
            <td>@emp.FullName</td>
            <td>
                <a asp-action="Edit" asp-route-id="@emp.EmployeeId" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@emp.EmployeeId" class="btn btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>