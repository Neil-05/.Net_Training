@model dynamic
@{
    ViewData["Title"] = "Search Results - SkySearcher";
    var searchType = ViewBag.SearchType;
    var persons = ViewBag.Persons;
}

<div class="results-container animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-end mb-4 px-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-secondary text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> New Search</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">Results</li>
                </ol>
            </nav>
            <h2 class="fw-800 mb-0">@searchType</h2>
            <p class="text-slate-700 mb-0">Best deals for <span class="fw-bold text-primary">@persons travelers</span></p>
        </div>
        <div class="text-end">
            <button class="btn btn-outline-slate btn-sm rounded-pill px-3" onclick="window.print()">
                <i class="fas fa-print me-1"></i> Print
            </button>
        </div>
    </div>

    @if (Model == null || ((System.Collections.IEnumerable)Model).GetEnumerator().MoveNext() == false)
    {
        <div class="search-card text-center py-5">
            <div class="mb-4">
                <div class="bg-slate-100 d-inline-flex p-4 rounded-circle">
                    <i class="fas fa-plane-slash fa-3x text-slate-300"></i>
                </div>
            </div>
            <h3 class="fw-bold">No Flights Found</h3>
            <p class="text-slate-700">We couldn't find any flights for this route. Try different cities or dates.</p>
            <a asp-action="Index" class="btn btn-primary px-5 mt-3">Modify Search</a>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="flight-ticket-card">
                <div class="ticket-segment flex-grow-1">
                    <div class="airline-info d-flex align-items-center me-4">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3">
                            <i class="fas fa-plane text-primary fa-lg"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-slate-900">@item.FlightName</div>
                            <div class="small text-slate-700">#@item.FlightId • @item.FlightType</div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center flex-grow-1 justify-content-center px-4">
                        <div class="text-center">
                            <div class="airport-code text-uppercase">@item.Source.Substring(0, 3)</div>
                            <div class="airport-name">@item.Source</div>
                        </div>

                        <div class="flight-line">
                            <span class="small text-slate-700 mb-1">Direct</span>
                            <div class="flight-path-icon">
                                <i class="fas fa-plane"></i>
                            </div>
                        </div>

                        <div class="text-center">
                            <div class="airport-code text-uppercase">@item.Destination.Substring(0, 3)</div>
                            <div class="airport-name">@item.Destination</div>
                        </div>
                    </div>
                </div>

                @if (searchType == "Flight + Hotel")
                {
                    <div class="hotel-addon px-4 border-start border-end border-slate-100 d-none d-lg-block" style="min-width: 200px;">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-hotel text-accent me-2"></i>
                            <div>
                                <div class="small fw-bold">Accommodation</div>
                                <div class="small text-slate-700 text-truncate" style="max-width: 150px;">@item.HotelName</div>
                            </div>
                        </div>
                    </div>
                }

                <div class="price-section">
                    <div class="small text-slate-700 mb-1">Total Price</div>
                    <div class="price-tag">@item.TotalCost.ToString("C")</div>
                    <button class="btn btn-primary btn-sm w-100 mt-2 rounded-pill">Select Flight</button>
                    @if (searchType == "Flight + Hotel")
                    {
                        <div class="small text-success fw-bold mt-1"><i class="fas fa-tags me-1"></i> Bundle Save</div>
                    }
                </div>
            </div>
        }

        <div class="text-center mt-5">
            <p class="text-slate-700 small">Prices include all taxes and fees. No hidden charges.</p>
        </div>
    }
</div>


